<UserControl x:Class="IndustrialDashboard.WinCcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:vm="clr-namespace:App.ViewModels;assembly=App.ViewModels"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <!-- Inverse bool to visibility -->
        <Style x:Key="OverlayChartStyle" TargetType="lvc:CartesianChart">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Margin" Value="0" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />   <!-- Toolbar -->
            <RowDefinition Height="*" />       <!-- Chart area -->
            <RowDefinition Height="Auto" />   <!-- Time slider -->
            <RowDefinition Height="Auto" />   <!-- Panel toggle -->
            <RowDefinition Height="Auto" />   <!-- Signals panel -->
            <RowDefinition Height="Auto" />   <!-- Status -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar ── -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Segment file -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Segment:" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0" />
                    <TextBox Text="{Binding SegmentDbPath, Mode=OneWay}" IsReadOnly="True"
                             Width="180" FontSize="11"
                             Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="Transparent" Padding="5,3" VerticalContentAlignment="Center" />
                    <Button Content="…" Click="BrowseSegment_Click" Style="{StaticResource PrimaryButton}"
                            Padding="8,3" Margin="4,0,0,0" FontSize="11" />
                </StackPanel>

                <!-- Tag file -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Tag map:" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0" />
                    <TextBox Text="{Binding TagDbPath, Mode=OneWay}" IsReadOnly="True"
                             Width="180" FontSize="11"
                             Background="{StaticResource CardBrush}" Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="Transparent" Padding="5,3" VerticalContentAlignment="Center" />
                    <Button Content="…" Click="BrowseTagDb_Click" Style="{StaticResource PrimaryButton}"
                            Padding="8,3" Margin="4,0,0,0" FontSize="11" />
                </StackPanel>

                <!-- Load tags -->
                <Button Grid.Column="2" Content="Load Tags" Command="{Binding LoadTagsCommand}"
                        Style="{StaticResource PrimaryButton}" Padding="12,5" Margin="0,0,8,0" FontSize="11" />

                <!-- Plot -->
                <Button Grid.Column="3" Content="▶ Plot" Command="{Binding PlotCommand}"
                        Style="{StaticResource PrimaryButton}" Padding="12,5" FontSize="11"
                        Background="#FF22883E" />

                <!-- Date range label -->
                <TextBlock Grid.Column="4" Text="{Binding DateRangeText}" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="16,0" />

                <!-- Chart mode toggle -->
                <Button Grid.Column="5" Content="{Binding ChartModeLabel}"
                        Command="{Binding ToggleChartModeCommand}"
                        Background="{StaticResource CardBrush}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        BorderBrush="Transparent" Padding="12,5" Cursor="Hand" FontSize="11"
                        Margin="0,0,8,0" />

                <!-- Loading indicator -->
                <ProgressBar Grid.Column="6" IsIndeterminate="True" Width="100" Height="4"
                             Foreground="{StaticResource AccentBrush}" Background="Transparent"
                             BorderBrush="Transparent"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
            </Grid>
        </Border>

        <!-- ── Chart area ── -->
        <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" CornerRadius="8">
            <Grid>
            <!-- Overlay mode (default visible, hidden in split mode via code-behind) -->
            <lvc:CartesianChart x:Name="OverlayChart"
                                Series="{Binding OverlaySeries}"
                                XAxes="{Binding OverlayXAxes}"
                                YAxes="{Binding OverlayYAxes}"
                                Background="Transparent" />

            <!-- Split mode — one chart per group stacked vertically (hidden by default) -->
            <ScrollViewer x:Name="SplitChart" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding GroupCharts}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:GroupChartVm}">
                        <Grid Height="160">
                            <lvc:CartesianChart Series="{Binding Series}"
                                               XAxes="{Binding XAxes}"
                                               YAxes="{Binding YAxes}"
                                               Background="Transparent" />
                            <TextBlock Text="{Binding Label}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="10" FontWeight="Bold"
                                       HorizontalAlignment="Right" VerticalAlignment="Top"
                                       Margin="0,4,8,0" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
            </ScrollViewer>
            </Grid>
        </Border>

        <!-- ── Time range slider ── -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                CornerRadius="8" Padding="12,8" Margin="0,6,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="TIME RANGE" FontSize="10" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />

                <!-- From slider -->
                <Grid Grid.Row="1" Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="From:" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <Slider Grid.Column="1"
                            Minimum="{Binding SliderMin}" Maximum="{Binding SliderMax}"
                            Value="{Binding SliderFrom}"
                            IsSnapToTickEnabled="False"
                            Foreground="{StaticResource AccentBrush}"
                            Margin="8,0" />
                    <TextBlock Grid.Column="2" Text="{Binding SliderFromLabel}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </Grid>

                <!-- To slider -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="140" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="To:" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <Slider Grid.Column="1"
                            Minimum="{Binding SliderMin}" Maximum="{Binding SliderMax}"
                            Value="{Binding SliderTo}"
                            IsSnapToTickEnabled="False"
                            Foreground="{StaticResource AccentBrush}"
                            Margin="8,0" />
                    <TextBlock Grid.Column="2" Text="{Binding SliderToLabel}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                </Grid>
            </Grid>
        </Border>

        <!-- ── Signals panel toggle ── -->
        <Button Grid.Row="3"
                Content="{Binding PanelToggleLabel}"
                Command="{Binding TogglePanelCommand}"
                Background="{StaticResource CardBrush}"
                Foreground="{StaticResource TextSecondaryBrush}"
                BorderBrush="Transparent"
                Padding="12,5" Cursor="Hand" FontSize="11"
                HorizontalAlignment="Left"
                Margin="0,4,0,0" />

        <!-- ── Signals panel ── -->
        <Border Grid.Row="4"
                Visibility="{Binding IsPanelVisible, Converter={StaticResource BoolToVis}}"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="8" Margin="0,4,0,0"
                MaxHeight="220">

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <DataGrid ItemsSource="{Binding Tags}"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          GridLinesVisibility="Horizontal"
                          HeadersVisibility="Column"
                          Background="{StaticResource SurfaceBrush}"
                          RowBackground="{StaticResource SurfaceBrush}"
                          AlternatingRowBackground="{StaticResource CardBrush}"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          BorderBrush="Transparent"
                          RowHeight="28"
                          ColumnHeaderHeight="30">

                    <DataGrid.ColumnHeaderStyle>
                        <Style TargetType="DataGridColumnHeader">
                            <Setter Property="Background" Value="{StaticResource CardBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
                            <Setter Property="FontSize" Value="10" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                            <Setter Property="Padding" Value="8,0" />
                            <Setter Property="BorderBrush" Value="Transparent" />
                        </Style>
                    </DataGrid.ColumnHeaderStyle>

                    <DataGrid.Columns>
                        <!-- Visible checkbox -->
                        <DataGridCheckBoxColumn Header="👁" Binding="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged}" Width="36" />

                        <!-- Tag name (read-only) -->
                        <DataGridTextColumn Header="Tag Name" Binding="{Binding TagName}" Width="*" IsReadOnly="True">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Padding" Value="8,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Color picker (combo) -->
                        <DataGridComboBoxColumn Header="Color"
                                                SelectedItemBinding="{Binding ColorHex, UpdateSourceTrigger=PropertyChanged}"
                                                ItemsSource="{x:Static vm:TagConfig.ColorPalette}"
                                                Width="110" />

                        <!-- Group -->
                        <DataGridComboBoxColumn Header="Group"
                                                SelectedItemBinding="{Binding GroupId, UpdateSourceTrigger=PropertyChanged}"
                                                ItemsSource="{x:Static vm:TagConfig.AvailableGroups}"
                                                Width="60" />

                        <!-- Min Y -->
                        <DataGridTextColumn Header="Min Y" Binding="{Binding MinY, StringFormat={}{0:F3}, UpdateSourceTrigger=PropertyChanged}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Courier New" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Padding" Value="8,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Max Y -->
                        <DataGridTextColumn Header="Max Y" Binding="{Binding MaxY, StringFormat={}{0:F3}, UpdateSourceTrigger=PropertyChanged}" Width="80">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="FontFamily" Value="Courier New" />
                                    <Setter Property="FontSize" Value="11" />
                                    <Setter Property="VerticalAlignment" Value="Center" />
                                    <Setter Property="Padding" Value="8,0" />
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Auto-scale button -->
                        <DataGridTemplateColumn Header="⟳" Width="44">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="⟳"
                                            Command="{Binding AutoScaleCommand}"
                                            Background="Transparent"
                                            BorderBrush="Transparent"
                                            Foreground="{StaticResource TextSecondaryBrush}"
                                            FontSize="14" Cursor="Hand"
                                            ToolTip="Auto-scale Y range from data" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </Border>

        <!-- ── Status bar ── -->
        <TextBlock Grid.Row="5" Text="{Binding StatusText}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="11" Margin="4,6,0,2" />
    </Grid>
</UserControl>
