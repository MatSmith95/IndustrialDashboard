<UserControl x:Class="IndustrialDashboard.WinCcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
             xmlns:vm="clr-namespace:App.ViewModels;assembly=App.ViewModels"
             xmlns:local="clr-namespace:IndustrialDashboard"
             Background="{StaticResource BackgroundBrush}">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:HexToColorBrushConverter x:Key="HexBrush" />
        <local:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <local:BoolToIndexConverter x:Key="BoolToIndexConverter" />
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Toolbar -->
            <RowDefinition Height="*" />     <!-- Main content -->
        </Grid.RowDefinitions>

        <!-- ══════════════════ TOOLBAR ══════════════════ -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                CornerRadius="8" Padding="10,8" Margin="0,0,0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Segment file -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Segment:" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding SegmentDbPath, Mode=OneWay}" IsReadOnly="True"
                             Width="160" FontSize="11" Background="{StaticResource CardBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="Transparent" Padding="5,3" VerticalContentAlignment="Center"/>
                    <Button Content="…" Click="BrowseSegment_Click" Style="{StaticResource PrimaryButton}"
                            Padding="8,3" Margin="4,0,0,0" FontSize="11"/>
                </StackPanel>

                <!-- Tag map file -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,12,0">
                    <TextBlock Text="Tag map:" VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <TextBox Text="{Binding TagDbPath, Mode=OneWay}" IsReadOnly="True"
                             Width="160" FontSize="11" Background="{StaticResource CardBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="Transparent" Padding="5,3" VerticalContentAlignment="Center"/>
                    <Button Content="…" Click="BrowseTagDb_Click" Style="{StaticResource PrimaryButton}"
                            Padding="8,3" Margin="4,0,0,0" FontSize="11"/>
                </StackPanel>

                <!-- Load Tags -->
                <Button Grid.Column="2" Content="Load Tags" Command="{Binding LoadTagsCommand}"
                        Style="{StaticResource PrimaryButton}" Padding="12,5" FontSize="11"/>

                <!-- Date range -->
                <TextBlock Grid.Column="3" Text="{Binding DateRangeText}" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="16,0"/>

                <!-- Plot button (shown in configure mode) -->
                <Button Grid.Column="4" Content="▶ Plot Graph"
                        Command="{Binding PlotCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Background="#FF22883E" Padding="14,5" FontSize="11" Margin="0,0,8,0"
                        Visibility="{Binding IsConfigureMode, Converter={StaticResource BoolToVis}}"/>

                <!-- Configure button (shown in graph mode) -->
                <Button Grid.Column="4" Content="⚙ Configure"
                        Command="{Binding GoToConfigureCommand}"
                        Background="{StaticResource CardBrush}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        BorderBrush="Transparent" Padding="14,5" Cursor="Hand" FontSize="11"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsConfigureMode, Converter={StaticResource InvBoolToVis}}"/>

                <!-- Split/Overlay (graph mode only) -->
                <Button Grid.Column="5" Content="{Binding ChartModeLabel}"
                        Command="{Binding ToggleChartModeCommand}"
                        Background="{StaticResource CardBrush}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        BorderBrush="Transparent" Padding="12,5" Cursor="Hand" FontSize="11"
                        Margin="0,0,8,0"
                        Visibility="{Binding IsConfigureMode, Converter={StaticResource InvBoolToVis}}"/>

                <!-- Loading bar -->
                <ProgressBar Grid.Column="6" IsIndeterminate="True" Width="80" Height="4"
                             Foreground="{StaticResource AccentBrush}" Background="Transparent"
                             BorderBrush="Transparent"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"/>
            </Grid>
        </Border>

        <!-- ══════════════════ MAIN CONTENT ══════════════════ -->
        <Grid Grid.Row="1">

            <!-- ── CONFIGURE VIEW ── -->
            <Grid Visibility="{Binding IsConfigureMode, Converter={StaticResource BoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Search + actions -->
                <Grid Grid.Row="0" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid Grid.Column="0">
                        <TextBox Text="{Binding TagSearch, UpdateSourceTrigger=PropertyChanged}"
                                 Background="{StaticResource CardBrush}"
                                 Foreground="{StaticResource TextPrimaryBrush}"
                                 BorderBrush="{StaticResource AccentBrush}" BorderThickness="1"
                                 Padding="8,6" FontSize="12" x:Name="TagSearchBox"/>
                        <TextBlock Text="🔍  Search tags…" IsHitTestVisible="False"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   FontSize="12" Padding="10,7"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TagSearch}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Button Grid.Column="1" Content="Select All"
                            Command="{Binding SelectAllCommand}"
                            Background="{StaticResource CardBrush}"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            BorderBrush="Transparent" Padding="12,6" Cursor="Hand" FontSize="11"
                            Margin="8,0,0,0"/>
                    <Button Grid.Column="2" Content="Clear"
                            Command="{Binding ClearSelectionCommand}"
                            Background="{StaticResource CardBrush}"
                            Foreground="{StaticResource TextSecondaryBrush}"
                            BorderBrush="Transparent" Padding="12,6" Cursor="Hand" FontSize="11"
                            Margin="4,0,0,0"/>
                </Grid>

                <!-- Time range slider -->
                <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="8" Padding="12,8" Margin="0,0,0,8">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding SliderLowerLabel}" FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <local:RangeSlider Grid.Column="1"
                                           Minimum="{Binding SliderMin}"
                                           Maximum="{Binding SliderMax}"
                                           LowerValue="{Binding SliderLower, Mode=TwoWay}"
                                           UpperValue="{Binding SliderUpper, Mode=TwoWay}"
                                           LowerLabel="{Binding SliderLowerLabel}"
                                           UpperLabel="{Binding SliderUpperLabel}" />
                        <TextBlock Grid.Column="2" Text="{Binding SliderUpperLabel}" FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Tag table -->
                <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="8">
                    <DataGrid ItemsSource="{Binding FilteredTags}"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False" CanUserDeleteRows="False"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              Background="{StaticResource SurfaceBrush}"
                              RowBackground="{StaticResource SurfaceBrush}"
                              AlternatingRowBackground="{StaticResource CardBrush}"
                              Foreground="{StaticResource TextPrimaryBrush}"
                              BorderBrush="Transparent"
                              RowHeight="28" ColumnHeaderHeight="30">

                        <DataGrid.ColumnHeaderStyle>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{StaticResource CardBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                <Setter Property="FontSize" Value="11"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Padding" Value="8,0"/>
                                <Setter Property="BorderBrush" Value="Transparent"/>
                            </Style>
                        </DataGrid.ColumnHeaderStyle>

                        <DataGrid.Columns>
                            <!-- Single-click checkbox (template col avoids double-click) -->
                            <DataGridTemplateColumn Header="☑" Width="36">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding IsSelected, UpdateSourceTrigger=PropertyChanged}"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <!-- Color picker — dropdown of colour swatches -->
                            <DataGridTemplateColumn Header="Color" Width="70">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Rectangle Width="32" Height="14" RadiusX="3" RadiusY="3"
                                                   Fill="{Binding ColorHex, Converter={StaticResource HexBrush}}"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <ComboBox SelectedItem="{Binding ColorHex, UpdateSourceTrigger=PropertyChanged}"
                                                  ItemsSource="{x:Static vm:TagConfig.ColorPalette}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Rectangle Width="32" Height="12" RadiusX="3" RadiusY="3"
                                                                   Fill="{Binding Converter={StaticResource HexBrush}}"
                                                                   Margin="0,0,6,0"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <!-- Tag name -->
                            <DataGridTextColumn Header="Tag Name" Binding="{Binding TagName}"
                                               Width="*" IsReadOnly="True">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Min value -->
                            <DataGridTextColumn Header="Min" Width="Auto" IsReadOnly="True"
                                               Binding="{Binding MinValue, StringFormat={}{0:F3}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Courier New"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Max value -->
                            <DataGridTextColumn Header="Max" Width="Auto" IsReadOnly="True"
                                               Binding="{Binding MaxValue, StringFormat={}{0:F3}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontFamily" Value="Courier New"/>
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>

                            <!-- Point count -->
                            <DataGridTextColumn Header="Points" Width="Auto" IsReadOnly="True"
                                               Binding="{Binding Points, StringFormat={}{0:N0}}">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontSize" Value="11"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                        <Setter Property="Padding" Value="8,0"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </Border>

                <!-- Status -->
                <TextBlock Grid.Row="3" Text="{Binding StatusText}" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="4,6,0,0"/>
            </Grid>

            <!-- ── GRAPH VIEW ── -->
            <Grid Visibility="{Binding IsConfigureMode, Converter={StaticResource InvBoolToVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />      <!-- Row 0: Chart -->
                    <RowDefinition Height="Auto" />   <!-- Row 1: Time slider -->
                    <RowDefinition Height="Auto" />   <!-- Row 2: Cursor values -->
                    <RowDefinition Height="Auto" />   <!-- Row 3: Live acquisition bar -->
                    <RowDefinition Height="Auto" />   <!-- Row 4: Panel toggle -->
                    <RowDefinition Height="Auto" />   <!-- Row 5: Signals panel -->
                    <RowDefinition Height="Auto" />   <!-- Row 6: Status -->
                </Grid.RowDefinitions>

                <!-- Chart area -->
                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="8">
                    <Grid>
                        <!-- Overlay chart -->
                        <lvc:CartesianChart x:Name="OverlayChart"
                                            Series="{Binding OverlaySeries}"
                                            XAxes="{Binding OverlayXAxes}"
                                            YAxes="{Binding OverlayYAxes}"
                                            TooltipPosition="Hidden"
                                            Background="Transparent"
                                            MouseMove="Chart_MouseMove" />

                        <!-- Split chart (hidden by default) -->
                        <ScrollViewer x:Name="SplitChart" Visibility="Collapsed"
                                      VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding GroupCharts}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:GroupChartVm}">
                                        <Grid Height="160">
                                            <lvc:CartesianChart Series="{Binding Series}"
                                                               XAxes="{Binding XAxes}"
                                                               YAxes="{Binding YAxes}"
                                                               TooltipPosition="Hidden"
                                                               Background="Transparent"
                                                               MouseMove="Chart_MouseMove"/>
                                            <TextBlock Text="{Binding Label}"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       FontSize="10" FontWeight="Bold"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Top" Margin="0,4,8,0"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Time range slider -->
                <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="8" Padding="12,8" Margin="0,6,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{Binding SliderLowerLabel}" FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="0,0,12,0"/>
                        <local:RangeSlider Grid.Column="1"
                                           Minimum="{Binding SliderMin}"
                                           Maximum="{Binding SliderMax}"
                                           LowerValue="{Binding SliderLower, Mode=TwoWay}"
                                           UpperValue="{Binding SliderUpper, Mode=TwoWay}"
                                           LowerLabel="{Binding SliderLowerLabel}"
                                           UpperLabel="{Binding SliderUpperLabel}" />
                        <TextBlock Grid.Column="2" Text="{Binding SliderUpperLabel}" FontSize="11"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   VerticalAlignment="Center" Margin="12,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Cursor value bar -->
                <Border Grid.Row="2" Background="{StaticResource CardBrush}"
                        CornerRadius="6" Padding="10,5" Margin="0,4,0,0">
                    <TextBlock Text="{Binding CursorText}" FontSize="11"
                               FontFamily="Courier New"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis" />
                </Border>

                <!-- Live acquisition bar -->
                <Border Grid.Row="3" Background="{StaticResource SurfaceBrush}"
                        CornerRadius="8" Padding="10,8" Margin="0,4,0,0">
                    <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                        <!-- Start/Stop button -->
                        <Button Content="{Binding LiveButtonLabel}"
                                Command="{Binding ToggleLiveCommand}"
                                Style="{StaticResource PrimaryButton}"
                                Background="#FF22883E" Padding="12,5" FontSize="11"
                                Margin="0,0,12,0"/>

                        <!-- Mode selector -->
                        <TextBlock Text="Mode:" VerticalAlignment="Center" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                        <ComboBox SelectedIndex="{Binding IsRollingMode, Converter={StaticResource BoolToIndexConverter}}"
                                  Width="150" FontSize="11" Margin="0,0,12,0"
                                  Background="{StaticResource CardBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}">
                            <ComboBoxItem>Append</ComboBoxItem>
                            <ComboBoxItem>Rolling Window</ComboBoxItem>
                        </ComboBox>

                        <!-- Rolling window size (only relevant in rolling mode) -->
                        <StackPanel Orientation="Horizontal"
                                    Visibility="{Binding IsRollingMode, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="Window (pts):" VerticalAlignment="Center" FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                            <ComboBox SelectedItem="{Binding RollingWindowSize}"
                                      Width="80" FontSize="11" Margin="0,0,12,0"
                                      Background="{StaticResource CardBrush}"
                                      Foreground="{StaticResource TextPrimaryBrush}">
                                <ComboBoxItem>500</ComboBoxItem>
                                <ComboBoxItem>1000</ComboBoxItem>
                                <ComboBoxItem>2000</ComboBoxItem>
                                <ComboBoxItem>5000</ComboBoxItem>
                            </ComboBox>
                        </StackPanel>

                        <!-- Poll interval -->
                        <TextBlock Text="Poll every:" VerticalAlignment="Center" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                        <ComboBox SelectedItem="{Binding PollIntervalSeconds}"
                                  Width="60" FontSize="11" Margin="0,0,16,0"
                                  Background="{StaticResource CardBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}">
                            <ComboBoxItem>1</ComboBoxItem>
                            <ComboBoxItem>2</ComboBoxItem>
                            <ComboBoxItem>5</ComboBoxItem>
                            <ComboBoxItem>10</ComboBoxItem>
                            <ComboBoxItem>30</ComboBoxItem>
                        </ComboBox>
                        <TextBlock Text="s" VerticalAlignment="Center" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,16,0"/>

                        <!-- Live status -->
                        <TextBlock Text="{Binding LiveStatusText}" FontSize="11"
                                   Foreground="{StaticResource GreenBrush}"
                                   VerticalAlignment="Center"/>
                    </WrapPanel>
                </Border>

                <!-- Signals panel toggle -->
                <Button Grid.Row="4" Content="{Binding PanelToggleLabel}"
                        Command="{Binding TogglePanelCommand}"
                        Background="{StaticResource CardBrush}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        BorderBrush="Transparent" Padding="12,5" Cursor="Hand"
                        FontSize="11" HorizontalAlignment="Left" Margin="0,4,0,0"/>

                <!-- Signals panel -->
                <Border Grid.Row="5"
                        Visibility="{Binding IsPanelVisible, Converter={StaticResource BoolToVis}}"
                        Background="{StaticResource SurfaceBrush}"
                        CornerRadius="8" Margin="0,4,0,0" MaxHeight="200">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <DataGrid ItemsSource="{Binding Tags}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  Background="{StaticResource SurfaceBrush}"
                                  RowBackground="{StaticResource SurfaceBrush}"
                                  AlternatingRowBackground="{StaticResource CardBrush}"
                                  Foreground="{StaticResource TextPrimaryBrush}"
                                  BorderBrush="Transparent"
                                  RowHeight="28" ColumnHeaderHeight="30">

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{StaticResource CardBrush}"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
                                    <Setter Property="FontSize" Value="11"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Padding" Value="8,0"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.Columns>
                                <!-- Single-click visibility toggle -->
                                <DataGridTemplateColumn Header="👁" Width="36">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsVisible, UpdateSourceTrigger=PropertyChanged}"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <!-- Color — swatch display, dropdown to change -->
                                <DataGridTemplateColumn Header="Color" Width="70">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Rectangle Width="32" Height="14" RadiusX="3" RadiusY="3"
                                                       Fill="{Binding ColorHex, Converter={StaticResource HexBrush}}"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                    <DataGridTemplateColumn.CellEditingTemplate>
                                        <DataTemplate>
                                            <ComboBox SelectedItem="{Binding ColorHex, UpdateSourceTrigger=PropertyChanged}"
                                                      ItemsSource="{x:Static vm:TagConfig.ColorPalette}">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Rectangle Width="32" Height="12" RadiusX="3" RadiusY="3"
                                                                   Fill="{Binding Converter={StaticResource HexBrush}}"/>
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellEditingTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Tag Name" Binding="{Binding TagName}"
                                                   Width="*" IsReadOnly="True">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridComboBoxColumn Header="Group" Width="Auto"
                                    SelectedItemBinding="{Binding GroupId, UpdateSourceTrigger=PropertyChanged}"
                                    ItemsSource="{x:Static vm:TagConfig.AvailableGroups}"/>

                                <DataGridTextColumn Header="Min Y" Width="Auto"
                                    Binding="{Binding MinY, StringFormat={}{0:F3}, UpdateSourceTrigger=PropertyChanged}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Courier New"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTextColumn Header="Max Y" Width="Auto"
                                    Binding="{Binding MaxY, StringFormat={}{0:F3}, UpdateSourceTrigger=PropertyChanged}">
                                    <DataGridTextColumn.ElementStyle>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="FontFamily" Value="Courier New"/>
                                            <Setter Property="FontSize" Value="11"/>
                                            <Setter Property="VerticalAlignment" Value="Center"/>
                                            <Setter Property="Padding" Value="8,0"/>
                                        </Style>
                                    </DataGridTextColumn.ElementStyle>
                                </DataGridTextColumn>

                                <DataGridTemplateColumn Header="⟳" Width="40">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Button Content="⟳" Command="{Binding AutoScaleCommand}"
                                                    Background="Transparent" BorderBrush="Transparent"
                                                    Foreground="{StaticResource TextSecondaryBrush}"
                                                    FontSize="14" Cursor="Hand"
                                                    ToolTip="Auto-scale from data"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </ScrollViewer>
                </Border>

                <!-- Status -->
                <TextBlock Grid.Row="6" Text="{Binding StatusText}" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="4,6,0,0"/>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
