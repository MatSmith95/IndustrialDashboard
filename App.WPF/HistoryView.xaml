<UserControl x:Class="IndustrialDashboard.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BackgroundBrush}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Filter bar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                CornerRadius="10" Padding="16,12" Margin="0,0,0,10">
            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                <TextBlock Text="Tag:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,8,0" />
                <ComboBox ItemsSource="{Binding AvailableTags}"
                          SelectedItem="{Binding SelectedTag}"
                          Width="140" Margin="0,0,20,0"
                          Background="{StaticResource CardBrush}"
                          Foreground="{StaticResource TextPrimaryBrush}" />

                <TextBlock Text="From:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,8,0" />
                <DatePicker SelectedDate="{Binding FromDate}"
                            Width="130" Margin="0,0,20,0"
                            Background="{StaticResource CardBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}" />

                <TextBlock Text="To:" VerticalAlignment="Center"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,8,0" />
                <DatePicker SelectedDate="{Binding ToDate}"
                            Width="130" Margin="0,0,20,0"
                            Background="{StaticResource CardBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}" />

                <Button Content="Load" Style="{StaticResource PrimaryButton}"
                        Command="{Binding LoadHistoryCommand}"
                        Margin="0,0,10,0" />

                <Button Content="Clear Filters"
                        Command="{Binding ClearFiltersCommand}"
                        Background="{StaticResource CardBrush}"
                        Foreground="{StaticResource TextSecondaryBrush}"
                        BorderBrush="Transparent"
                        Padding="14,8" Cursor="Hand" />
            </WrapPanel>
        </Border>

        <!-- Data grid -->
        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding Entries}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="{StaticResource SurfaceBrush}"
                  RowBackground="{StaticResource SurfaceBrush}"
                  AlternatingRowBackground="{StaticResource CardBrush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  BorderBrush="Transparent"
                  HorizontalScrollBarVisibility="Auto"
                  VerticalScrollBarVisibility="Auto"
                  ColumnHeaderHeight="36"
                  RowHeight="30">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"  Value="{StaticResource CardBrush}" />
                    <Setter Property="Foreground"  Value="{StaticResource TextSecondaryBrush}" />
                    <Setter Property="FontSize"    Value="11" />
                    <Setter Property="FontWeight"  Value="SemiBold" />
                    <Setter Property="Padding"     Value="12,0" />
                    <Setter Property="BorderBrush" Value="Transparent" />
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID"
                                    Binding="{Binding Id}"
                                    Width="70" />
                <DataGridTextColumn Header="Timestamp"
                                    Binding="{Binding Timestamp, StringFormat={}{0:yyyy-MM-dd HH:mm:ss.fff}}"
                                    Width="200" />
                <DataGridTextColumn Header="Tag Name"
                                    Binding="{Binding TagName}"
                                    Width="130" />
                <DataGridTextColumn Header="Value"
                                    Binding="{Binding Value, StringFormat={}{0:F4}}"
                                    Width="*" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- Status bar -->
        <TextBlock Grid.Row="2"
                   Text="{Binding StatusText}"
                   Foreground="{StaticResource TextSecondaryBrush}"
                   FontSize="12"
                   Margin="4,6,0,0" />
    </Grid>
</UserControl>
