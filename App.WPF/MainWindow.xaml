<Window x:Class="App.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:vm="clr-namespace:App.ViewModels;assembly=App.ViewModels"
        Title="Industrial Data Dashboard"
        Height="780" Width="1280"
        MinHeight="620" MinWidth="900"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Value card template -->
        <DataTemplate x:Key="ValueCard">
            <Border Background="{StaticResource CardBrush}"
                    CornerRadius="10" Padding="20" Margin="6">
                <StackPanel>
                    <TextBlock Text="{Binding Label}"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <TextBlock Text="{Binding Value, StringFormat={}{0:F2}}"
                               FontSize="42" FontWeight="Bold"
                               Foreground="{Binding ValueBrush}"
                               Margin="0,6,0,0" />
                    <TextBlock Text="{Binding Unit}"
                               FontSize="14"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60" />   <!-- Header -->
            <RowDefinition Height="*" />    <!-- Content -->
            <RowDefinition Height="32" />   <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Header ── -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}">
            <Grid Margin="20,0">
                <TextBlock Text="⚙  INDUSTRIAL DATA DASHBOARD"
                           VerticalAlignment="Center"
                           FontSize="18" FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}" />
                <Button Style="{StaticResource PrimaryButton}"
                        Content="{Binding StartStopLabel}"
                        Command="{Binding ToggleAcquisitionCommand}"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center" />
            </Grid>
        </Border>

        <!-- ── Main content tabs ── -->
        <TabControl Grid.Row="1"
                    Background="{StaticResource BackgroundBrush}"
                    BorderBrush="Transparent"
                    Margin="0">

            <!-- Live Dashboard Tab -->
            <TabItem Header="Live Dashboard" Style="{StaticResource DarkTab}">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="140" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Value cards -->
                    <UniformGrid Grid.Row="0" Columns="3">
                        <!-- Temperature -->
                        <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="20" Margin="6">
                            <StackPanel>
                                <TextBlock Text="TEMPERATURE" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding CurrentTemperature, StringFormat={}{0:F2}}"
                                           FontSize="44" FontWeight="Bold"
                                           Foreground="{StaticResource OrangeBrush}" Margin="0,4,0,0" />
                                <TextBlock Text="°C" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Pressure -->
                        <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="20" Margin="6">
                            <StackPanel>
                                <TextBlock Text="PRESSURE" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding CurrentPressure, StringFormat={}{0:F4}}"
                                           FontSize="44" FontWeight="Bold"
                                           Foreground="{StaticResource BlueBrush}" Margin="0,4,0,0" />
                                <TextBlock Text="bar" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Motor Speed -->
                        <Border Background="{StaticResource CardBrush}" CornerRadius="10" Padding="20" Margin="6">
                            <StackPanel>
                                <TextBlock Text="MOTOR SPEED" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                <TextBlock Text="{Binding CurrentMotorSpeed, StringFormat={}{0:F0}}"
                                           FontSize="44" FontWeight="Bold"
                                           Foreground="{StaticResource GreenBrush}" Margin="0,4,0,0" />
                                <TextBlock Text="RPM" FontSize="14"
                                           Foreground="{StaticResource TextSecondaryBrush}" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <!-- Live chart -->
                    <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}"
                            CornerRadius="10" Margin="6">
                        <Grid>
                            <TextBlock Text="LIVE TREND — ROLLING 60 POINT WINDOW"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="16,12,0,0"
                                       VerticalAlignment="Top" />
                            <lvc:CartesianChart Series="{Binding Series}"
                                               XAxes="{Binding XAxes}"
                                               YAxes="{Binding YAxes}"
                                               Margin="0,30,0,0"
                                               Background="Transparent" />
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <!-- History Tab -->
            <TabItem Header="Data History" Style="{StaticResource DarkTab}"
                     x:Name="HistoryTab">
                <Grid x:Name="HistoryContainer" Margin="12" />
            </TabItem>

            <!-- WinCC Log Viewer Tab -->
            <TabItem Header="WinCC Log Viewer" Style="{StaticResource DarkTab}"
                     x:Name="WinCcTab">
                <Grid x:Name="WinCcContainer" Margin="12" />
            </TabItem>

        </TabControl>

        <!-- ── Status bar ── -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}">
            <Grid Margin="16,0">
                <TextBlock Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" />
                <TextBlock Text="Royal IHC — Industrial Dashboard v1.0"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" />
            </Grid>
        </Border>
    </Grid>
</Window>
