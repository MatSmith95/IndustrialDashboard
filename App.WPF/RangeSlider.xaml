<UserControl x:Class="IndustrialDashboard.RangeSlider"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="32">
    <Grid x:Name="Root" Margin="0,4">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Track background -->
        <Border Grid.Row="0" Height="4" CornerRadius="2"
                Background="#FF444466" Margin="10,0" VerticalAlignment="Center" />

        <!-- Selection highlight -->
        <Border Grid.Row="0" x:Name="SelectionHighlight"
                Height="4" CornerRadius="2" VerticalAlignment="Center"
                Background="#FFE94560"
                HorizontalAlignment="Left" />

        <!-- From thumb -->
        <Thumb Grid.Row="0" x:Name="LowerThumb"
               Width="16" Height="16"
               VerticalAlignment="Center"
               HorizontalAlignment="Left"
               Cursor="SizeWE"
               DragDelta="LowerThumb_DragDelta"
               Style="{StaticResource ThumbStyle}" />

        <!-- To thumb -->
        <Thumb Grid.Row="0" x:Name="UpperThumb"
               Width="16" Height="16"
               VerticalAlignment="Center"
               HorizontalAlignment="Left"
               Cursor="SizeWE"
               DragDelta="UpperThumb_DragDelta"
               Style="{StaticResource ThumbStyle}" />

        <!-- Labels -->
        <Grid Grid.Row="1" Margin="10,4,10,0">
            <TextBlock x:Name="LowerLabel" Text="" FontSize="10"
                       Foreground="#FF9E9E9E" HorizontalAlignment="Left" />
            <TextBlock x:Name="UpperLabel" Text="" FontSize="10"
                       Foreground="#FF9E9E9E" HorizontalAlignment="Right" />
        </Grid>
    </Grid>
</UserControl>
