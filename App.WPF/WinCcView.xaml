<UserControl x:Class="IndustrialDashboard.WinCcView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"

             Background="{StaticResource BackgroundBrush}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ── Left panel: file selection + tag list ── -->
        <Border Grid.Column="0" Background="{StaticResource SurfaceBrush}"
                Margin="0,0,8,0" CornerRadius="10" Padding="14">
            <StackPanel>
                <TextBlock Text="WINCC UNIFIED LOG VIEWER"
                           FontSize="11" FontWeight="SemiBold"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           Margin="0,0,0,14" />

                <!-- Segment DB -->
                <TextBlock Text="Segment .db3 (data)" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SegmentDbPath, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="{StaticResource CardBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="Transparent"
                             Padding="6,4" FontSize="11" />
                    <Button Grid.Column="1" Content="Browse"
                            Click="BrowseSegment_Click"
                            Style="{StaticResource PrimaryButton}"
                            Padding="10,4" Margin="4,0,0,0" FontSize="11" />
                </Grid>

                <!-- Tag DB -->
                <TextBlock Text="Tag map .db3 (tag names)" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding TagDbPath, Mode=OneWay}"
                             IsReadOnly="True"
                             Background="{StaticResource CardBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="Transparent"
                             Padding="6,4" FontSize="11" />
                    <Button Grid.Column="1" Content="Browse"
                            Click="BrowseTagDb_Click"
                            Style="{StaticResource PrimaryButton}"
                            Padding="10,4" Margin="4,0,0,0" FontSize="11" />
                </Grid>

                <!-- Date range -->
                <TextBlock Text="From" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding FromDate}" Margin="0,0,0,8"
                            Background="{StaticResource CardBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}" />

                <TextBlock Text="To" FontSize="11"
                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,4" />
                <DatePicker SelectedDate="{Binding ToDate}" Margin="0,0,0,12"
                            Background="{StaticResource CardBrush}"
                            Foreground="{StaticResource TextPrimaryBrush}" />

                <Button Content="Load Tags"
                        Command="{Binding LoadTagsCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,0,0,14" />

                <!-- Tag list -->
                <Grid Margin="0,0,0,6">
                    <TextBlock Text="Tags" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="All" Command="{Binding SelectAllTagsCommand}"
                                Background="{StaticResource CardBrush}"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                BorderBrush="Transparent" Padding="6,2" FontSize="10" Cursor="Hand" />
                        <Button Content="None" Command="{Binding ClearTagSelectionCommand}"
                                Background="{StaticResource CardBrush}"
                                Foreground="{StaticResource TextSecondaryBrush}"
                                BorderBrush="Transparent" Padding="6,2" FontSize="10" Cursor="Hand"
                                Margin="4,0,0,0" />
                    </StackPanel>
                </Grid>

                <ListBox ItemsSource="{Binding AvailableTags}"
                         Background="{StaticResource CardBrush}"
                         BorderBrush="Transparent"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         MaxHeight="280" ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding IsSelected}"
                                      Content="{Binding TagName}"
                                      Foreground="{StaticResource TextPrimaryBrush}"
                                      FontSize="11" Padding="4,2" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <Button Content="Plot Selected Tags"
                        Command="{Binding LoadDataCommand}"
                        Style="{StaticResource PrimaryButton}"
                        Margin="0,12,0,0" />

                <ProgressBar IsIndeterminate="{Binding IsLoading}"
                             Height="3" Margin="0,10,0,0"
                             Foreground="{StaticResource AccentBrush}"
                             Background="Transparent"
                             BorderBrush="Transparent"
                             Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}" />
            </StackPanel>
        </Border>

        <!-- ── Right panel: chart ── -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="10">
                <Grid>
                    <TextBlock Text="TAG VALUES OVER TIME"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="16,12,0,0" VerticalAlignment="Top" />

                    <lvc:CartesianChart Series="{Binding Series}"
                                       XAxes="{Binding XAxes}"
                                       YAxes="{Binding YAxes}"
                                       Margin="0,30,0,0"
                                       Background="Transparent" />

                    <TextBlock Text="No data loaded — select files and tags then click 'Plot Selected Tags'"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center"
                               Visibility="{Binding HasNoSeries, Converter={StaticResource BoolToVis}}" />
                </Grid>
            </Border>

            <TextBlock Grid.Row="1"
                       Text="{Binding StatusText}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontSize="11" Margin="4,6,0,0" />
        </Grid>
    </Grid>
</UserControl>
